<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/main.css">
</head>

<body>

    <header>
        <h1>My Notes</h1>
        <nav>
            <a href="/post-note">Post Notes</a>
            <a href="#">Contact</a>
        </nav>
    </header>




    <section class="notes">

        <% if (notes && notes.length> 0) { %>

            <% notes.forEach(note=> { %>
                <div class="note-card">
                    <h3>
                        <%= note.title %>
                    </h3>
                    <p>
                        <%= note.content %>
                    </p>

                    <form action="/delete-note" method="POST">
                        <input type="hidden" name="noteId" value="<%= note.id %>">
                        <button class="delete-btn" type="submit">Delete</button>
                    </form>
                </div>
                <% }) %>

                    <% } else { %>
                        <div class="note-card">
                            <h3>Welcome Note</h3>
                            <p>Welcome To Notes web :)</p>
                        </div>

                        <p class="empty-msg">No notes yet. Create one!</p>

                        <% } %>

    </section>

    <footer>
        <p>© 2026 My Notes App</p>
    </footer>

</body>

</html>